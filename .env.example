# 서버 전용 — pg.Pool이 사용. 브라우저에는 절대 노출되지 않음.
DATABASE_URL=postgres://user:password@host:5432/dbname

# 브라우저에 GET /api/config 를 통해 그대로 노출됨 (Supabase Realtime 구독용).
# anon key는 노출을 전제로 설계된 키이며 RLS 정책으로 보호해야 함 — sql/enable_realtime.sql 참고.
# 절대 service_role 키를 넣지 말 것.
SUPABASE_URL=https://your-project.example.com
SUPABASE_ANON_KEY=your-anon-key-here

PORT=4747
